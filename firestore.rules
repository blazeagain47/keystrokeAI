// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own profile data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Typing sessions - users can only access their own sessions
    match /typingSessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    // Leaderboards - read-only for authenticated users
    match /leaderboards/{leaderboardId} {
      allow read: if request.auth != null;
      allow write: if false; // Only server functions can write to leaderboards
    }
    
    // Public text content - read-only for authenticated users
    match /textContent/{contentId} {
      allow read: if request.auth != null;
      allow write: if false; // Only admins can modify text content
    }
    
    // User achievements - users can only read their own
    match /achievements/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only server functions can award achievements
    }
    
    // Daily challenges - read-only for authenticated users
    match /dailyChallenges/{challengeId} {
      allow read: if request.auth != null;
      allow write: if false; // Only server functions can create challenges
    }
    
    // User challenge progress - users can only access their own
    match /challengeProgress/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Runs written by server; a user may read only their own runs
    match /runs_v1/{runId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false; // writes via Admin only
    }

    // Per-user totals; user can read only their own totals
    match /user_totals_v1/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // writes via Admin only
    }

    // 1v1 party audit rows. The PartyKit room is the source of truth for
    // live gameplay; this collection only stores creation + finish audit.
    // All client reads/writes are denied — the Next.js API routes
    // (/api/party/create, /api/party/join) use the Admin SDK and bypass
    // these rules. This prevents enumeration of active party codes by
    // unauthenticated clients.
    match /parties_v1/{partyId} {
      allow read, write: if false;
    }

    // Reserved placeholder for the per-player final result rows that
    // Phase 6 will write from the server. Locked down today so accidental
    // direct client writes during development are impossible.
    match /party_results_v1/{resultId} {
      allow read, write: if false;
    }
  }
}