# Copy this file to `.env.local` (for the Next.js app) and, on the VPS,
# to `.env` (for `docker compose`). Never commit the real filled-in files.

# ---------------------------------------------------------------------------
# Next.js app (Vercel) — used by src/lib/firebaseAdmin.ts, src/lib/firebase.ts
# ---------------------------------------------------------------------------

# Firebase Admin (server-side; Firestore game data, not auth)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-XXXXX@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nABC...XYZ\n-----END PRIVATE KEY-----\n"

# Firebase client config (public, safe to expose in the browser bundle)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Points the Next.js API proxies (src/app/api/auth/*) at the backend.
# Local dev default (matches `uvicorn` running on 127.0.0.1:8000):
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# Production: https://api.yourdomain.com (must match PUBLIC_API_DOMAIN below)

# Ads (optional)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_HOME=
NEXT_PUBLIC_ADSENSE_SLOT_RESULTS=
NEXT_PUBLIC_ADSENSE_SLOT_STATS=

# PartyKit (realtime)
PARTYKIT_HOST=127.0.0.1:1999
PARTYKIT_ADMIN_TOKEN=

# ---------------------------------------------------------------------------
# Backend (FastAPI + Postgres, self-hosted via docker-compose.yml on the VPS)
# ---------------------------------------------------------------------------

# Marks the backend as production: enables `Secure` cookies and disables the
# local SQLite fallback in backend/database.py. Leave unset for local dev.
APP_ENV=production

# Postgres credentials used by the `postgres` service in docker-compose.yml.
POSTGRES_USER=blazekey
POSTGRES_PASSWORD=change_me_to_a_long_random_value
POSTGRES_DB=blazekey

# For local (non-docker) backend dev against a local/remote Postgres instead
# of the SQLite dev fallback. Not needed when running via docker-compose
# (docker-compose.yml builds this from the POSTGRES_* vars above).
DATABASE_URL=postgresql://blazekey:change_me_to_a_long_random_value@localhost:5432/blazekey

# Must be a long, random, secret value — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Anyone who has this can forge a valid login session for any account.
KS_JWT_SECRET=

KS_JWT_TTL_SECONDS=604800
JWT_COOKIE_NAME=ks_session
JWT_COOKIE_TTL_DAYS=7

# Comma-separated list of origins allowed to call the backend directly.
# The Next.js API routes proxy server-side (not subject to CORS), so this
# mainly matters for direct browser calls / local dev tooling.
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,https://yourapp.vercel.app

# Domain Caddy requests a TLS certificate for and reverse-proxies to the api
# container (docker-compose.yml + Caddyfile). Must have DNS already pointed
# at the VPS's IP before starting the stack.
PUBLIC_API_DOMAIN=api.yourdomain.com
